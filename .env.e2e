# Committed overrides for Playwright E2E (`next build && next start` on port 3100).
# Loaded after .env.development; see scripts/load-app-env.mjs and ENV.md.
# ALLOW_LOCAL_STACK_ENV bypasses production build guards for this test build only.

ALLOW_LOCAL_STACK_ENV=1
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3100
E2E_AUTO_LINK_AUTH_PROFILE=1
