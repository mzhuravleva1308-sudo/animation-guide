# Personal secrets only — copy to .env.local (never commit).
# Local Supabase + Mailpit: automatic via .env.development + `npm run dev` (see ENV.md).
# Hosted Supabase (scripts / production): .env.hosted.local or deployment dashboard — not here.

OPENAI_API_KEY=
TMDB_API_KEY=

# Optional canonical site URL override (default for dev is in .env.development)
# NEXT_PUBLIC_SITE_URL=

# Comma-separated OAuth providers on /login (e.g. apple,google).
# Omit or leave unset to hide OAuth until provider credentials are ready.
# NEXT_PUBLIC_AUTH_OAUTH_PROVIDERS=apple,google
