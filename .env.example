# Copy to .env.local and fill in real values. Never commit .env.local.

# App (client-safe — anon key only in lib/supabase.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — E2E reset + scripts. Never NEXT_PUBLIC_. Never commit.
SUPABASE_SERVICE_ROLE_KEY=

# Dedicated E2E test profile ONLY (/p/{slug}?token=...). May be mutated by tests; reset cleans it.
# Do not use Maria's real profile.
E2E_PROFILE_SLUG=
E2E_PROFILE_TOKEN=

# Optional
OPENAI_API_KEY=
TMDB_API_KEY=
