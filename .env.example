# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Hosted Supabase (production / staging) ---
# App (client-safe — anon key only in lib/supabase.ts and lib/supabase/{client,server}.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Local Supabase CLI (development + Mailpit OTP testing) ---
# After `supabase start`, run `supabase status -o env` and copy these values into .env.local:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY from supabase status>
# SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY from supabase status>
# MAILPIT_URL=http://127.0.0.1:54324
#
# Use synthetic addresses freely in local dev (for example otp-test-1@example.com).
# Auth emails are captured by Mailpit and are not sent externally.

# Optional canonical site URL for auth redirects (recommended: http://127.0.0.1:3000 locally)
NEXT_PUBLIC_SITE_URL=

# Comma-separated OAuth providers on /login (e.g. apple,google).
# Omit or leave unset to hide OAuth until provider credentials are ready.
# Set to an empty string to hide OAuth explicitly.
# NEXT_PUBLIC_AUTH_OAUTH_PROVIDERS=apple,google

# Server-side only — E2E reset + scripts. Never NEXT_PUBLIC_. Never commit.
SUPABASE_SERVICE_ROLE_KEY=

# Dedicated E2E test profile ONLY (/p/{slug}?token=...). May be mutated by tests; reset cleans it.
# Do not use Maria's real profile.
# Local seed (supabase/seed.sql): slug e2e-test, token local-e2e-test-token
E2E_PROFILE_SLUG=e2e-test
E2E_PROFILE_TOKEN=local-e2e-test-token

# Optional
OPENAI_API_KEY=
TMDB_API_KEY=
