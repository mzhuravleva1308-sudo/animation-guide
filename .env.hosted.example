# Copy to .env.hosted.local (gitignored) when running scripts against hosted Supabase.
# NOT loaded by `npm run dev`, E2E, or production deployment.
# Use: APP_ENV=hosted node scripts/<name>.mjs

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Production SMTP is configured in the Supabase Dashboard — not in this repo.
